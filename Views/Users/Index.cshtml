@using FastFood.Models
@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Users";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Users</h1>
    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">+ Register User</a>
</div>

<div class="ff-table-wrap">
    <table class="table ff-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-center text-muted py-4">No users found.</td></tr>
            }
            @for (int i = 0; i < Model.Count(); i++)
            {
                var user = Model.ElementAt(i);
                <tr>
                    <td class="text-muted">@(i + 1)</td>
                    <td class="fw-500">@user.Name</td>
                    <td>@user.Email</td>
                    <td class="text-center">
                        <a asp-controller="Users" asp-action="Edit"   asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm btn-action">
                            <i class="fas fa-edit me-1"></i>Edit
                        </a>
                        <a asp-controller="Users" asp-action="Delete" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm btn-action">
                            <i class="fas fa-trash-alt me-1"></i>Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
