@model IEnumerable<FastFood.Models.Cart>
@{
    ViewData["Title"] = "Cart";
    double totalCartPrice = Model.Sum(item => item.Item.Price * item.Count);
}

<div class="ff-page-header">
    <h1 class="ff-page-title"><i class="fas fa-shopping-cart me-2"></i>My Cart</h1>
</div>

@if (!Model.Any())
{
    <div class="ff-summary-box text-center py-5">
        <i class="fas fa-shopping-basket fa-3x text-muted mb-3 d-block"></i>
        <p class="text-muted mb-3">Your cart is empty.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Browse Menu</a>
    </div>
}
else
{
    <div class="ff-table-wrap mb-4">
        <table class="table ff-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Qty</th>
                    <th>Unit Price</th>
                    <th>Subtotal</th>
                    <th class="text-center">Remove</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    double subtotal = item.Item.Price * item.Count;
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@item.Item.ImageUrl" class="ff-cart-thumb" alt="@item.Item.Title"
                                     onerror="this.onerror=null;this.src='https://placehold.co/44x44/f3f4f6/adb5bd?text=?'" />
                                <span class="fw-500">@item.Item.Title</span>
                            </div>
                        </td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-2">
                                <input type="hidden" name="cartId" value="@item.Id" />
                                <input type="number" name="newQuantity" value="@item.Count"
                                       class="form-control form-control-sm" style="width:70px;" min="1" />
                                <button type="submit" class="btn btn-outline-primary btn-sm">Update</button>
                            </form>
                        </td>
                        <td>$@item.Item.Price.ToString("0.00")</td>
                        <td class="fw-600">$@subtotal.ToString("0.00")</td>
                        <td class="text-center">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm btn-action">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-end">
        <div class="ff-summary-box" style="min-width:280px;">
            <div class="d-flex justify-content-between mb-3">
                <span class="text-muted">Total</span>
                <span class="ff-summary-total">$@totalCartPrice.ToString("0.00")</span>
            </div>
            <a asp-action="Summary" class="btn btn-primary w-100">Proceed to Order →</a>
        </div>
    </div>
}
