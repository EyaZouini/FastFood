@model FastFood.ViewModels.OrderDetailsViewModel
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Order #@Model.OrderHeader.Id</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Orders</a>
</div>

<div class="row g-4">
    <!-- Order lines -->
    <div class="col-lg-8">
        <div class="ff-table-wrap">
            <table class="table ff-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Name</th>
                        <th>Unit Price</th>
                        <th>Qty</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in Model.OrderDetails)
                    {
                        <tr>
                            <td>
                                <img src="@detail.Item.ImageUrl" class="ff-cart-thumb" alt="@detail.Name"
                                     onerror="this.onerror=null;this.src='https://placehold.co/44x44/f3f4f6/adb5bd?text=?'" />
                            </td>
                            <td>@detail.Name</td>
                            <td>$@detail.Price.ToString("0.00")</td>
                            <td>@detail.Count</td>
                            <td class="text-end fw-600">$@((detail.Price * detail.Count).ToString("0.00"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Order info -->
    <div class="col-lg-4">
        <div class="ff-summary-box">
            <h5 class="fw-bold mb-3">Order Info</h5>
            <dl class="row mb-0 small">
                <dt class="col-5 text-muted fw-normal">Customer</dt>
                <dd class="col-7 fw-500">@Model.OrderHeader.Name</dd>
                <dt class="col-5 text-muted fw-normal">Phone</dt>
                <dd class="col-7">@Model.OrderHeader.Phone</dd>
                <dt class="col-5 text-muted fw-normal">Pick-up</dt>
                <dd class="col-7">@Model.OrderHeader.TimeOfPick.ToString("f")</dd>
                <dt class="col-5 text-muted fw-normal">Order Date</dt>
                <dd class="col-7">@Model.OrderHeader.OrderDate.ToString("dd MMM yyyy")</dd>
            </dl>
            <hr class="ff-hr" />
            <div class="d-flex justify-content-between">
                <span class="fw-600">Total</span>
                <span class="ff-summary-total">$@Model.OrderHeader.OrderTotal.ToString("0.00")</span>
            </div>
        </div>
    </div>
</div>
