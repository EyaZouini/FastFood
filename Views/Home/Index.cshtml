@model IEnumerable<FastFood.Models.Item>
@{
    ViewData["Title"] = "Our Menu";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Our Menu</h1>
</div>

<form method="get" class="mb-4">
    <div class="input-group" style="max-width:480px;">
        <input type="text" name="searchQuery" placeholder="Search a dish…" class="form-control" />
        <button type="submit" class="btn btn-primary px-4">Search</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-search fa-2x mb-2 d-block"></i>
        No items found for your search.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="ff-food-card h-100 d-flex flex-column">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title"
                         onerror="this.onerror=null;this.src='https://placehold.co/400x300/f3f4f6/adb5bd?text=No+Image'">
                    <div class="card-body d-flex flex-column p-3">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-desc flex-grow-1">@item.Description</p>
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-2">
                            <span class="ff-price">$@item.Price.ToString("0.00")</span>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm px-3">View</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
