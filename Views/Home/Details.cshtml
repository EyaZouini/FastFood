@model FastFood.Models.Cart
@{
    ViewData["Title"] = "Product Details";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Product Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Menu</a>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-5">
        <div class="ff-form-card p-0 overflow-hidden">
            <img src="@Model.Item.ImageUrl" alt="@Model.Item.Title" class="w-100"
                 style="height:300px;object-fit:cover;"
                 onerror="this.onerror=null;this.src='https://placehold.co/600x300/f3f4f6/adb5bd?text=No+Image'" />
        </div>
    </div>
    <div class="col-md-5">
        <div class="ff-form-card h-100 d-flex flex-column">
            <h2 class="fw-bold mb-1">@Model.Item.Title</h2>
            <span class="ff-price fs-4 mb-3">$@Model.Item.Price.ToString("0.00")</span>
            <p class="text-muted mb-1"><strong>Category:</strong> @Model.Item.SubCategory.Title</p>
            <p class="text-muted mb-3 lh-lg">@Model.Item.Description</p>

            <form asp-action="Details" method="post" class="mt-auto">
                <input type="hidden" name="ItemId" value="@Model.ItemId" />
                <div class="mb-3">
                    <label class="form-label fw-500">Quantity</label>
                    <input type="number" asp-for="Count" class="form-control" style="max-width:120px;" value="@Model.Count" min="1" required />
                </div>
                @if (User.IsInRole("Customer"))
                {
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-cart-plus me-1"></i> Add to Cart
                    </button>
                }
            </form>
        </div>
    </div>
</div>
