@model IEnumerable<FastFood.Models.Item>
@{
    ViewData["Title"] = "Items";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Items</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Item</a>
</div>

<div class="ff-table-wrap">
    <table class="table ff-table">
        <thead>
            <tr>
                <th>Image</th>
                <th>Title</th>
                <th>Description</th>
                <th>Price</th>
                <th>Sub-Category</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Title" class="ff-cart-thumb"
                                 onerror="this.onerror=null;this.src='https://placehold.co/44x44/f3f4f6/adb5bd?text=?'" />
                        }
                    </td>
                    <td class="fw-500">@item.Title</td>
                    <td class="text-muted small" style="max-width:250px;">
                        <span style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                            @item.Description
                        </span>
                    </td>
                    <td>$@item.Price.ToString("0.00")</td>
                    <td>@item.SubCategory.Title</td>
                    <td class="text-center">
                        <a asp-action="Edit"    asp-route-id="@item.Id" class="btn btn-outline-primary  btn-sm btn-action">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm btn-action">Details</a>
                        <a asp-action="Delete"  asp-route-id="@item.Id" class="btn btn-outline-danger   btn-sm btn-action">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
