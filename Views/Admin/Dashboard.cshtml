@model FastFood.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2 class="fw-bold mb-0">Admin Dashboard</h2>
    <span class="text-muted small">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</span>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fas fa-dollar-sign fa-lg text-primary"></i>
                </div>
                <div>
                    <div class="text-muted small">Revenue Today</div>
                    <div class="fw-bold fs-5">$@Model.RevenueToday.ToString("0.00")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fas fa-calendar-alt fa-lg text-success"></i>
                </div>
                <div>
                    <div class="text-muted small">Revenue This Month</div>
                    <div class="fw-bold fs-5">$@Model.RevenueThisMonth.ToString("0.00")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fas fa-chart-line fa-lg text-warning"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Revenue</div>
                    <div class="fw-bold fs-5">$@Model.RevenueTotal.ToString("0.00")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="fas fa-shopping-bag fa-lg text-info"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Orders</div>
                    <div class="fw-bold fs-5">@Model.TotalOrders <span class="fs-6 fw-normal text-muted">(today: @Model.OrdersToday)</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts row -->
<div class="row g-3 mb-4">
    <!-- Orders per day chart -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-bold mb-0">Orders — Last 7 Days</h6>
            </div>
            <div class="card-body">
                <canvas id="ordersChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <!-- Top items chart -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 pb-0">
                <h6 class="fw-bold mb-0">Top 5 Most Ordered Items</h6>
            </div>
            <div class="card-body">
                @if (Model.TopItemNames.Count == 0)
                {
                    <p class="text-muted text-center mt-4">No order data yet.</p>
                }
                else
                {
                    <canvas id="topItemsChart" height="180"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Orders per day bar chart
        const ordersCtx = document.getElementById('ordersChart').getContext('2d');
        new Chart(ordersCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrdersPerDayLabels)),
                datasets: [{
                    label: 'Orders',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrdersPerDayCounts)),
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 } }
                }
            }
        });

        // Top items horizontal bar chart
        @if (Model.TopItemNames.Count > 0)
        {
            <text>
            const topCtx = document.getElementById('topItemsChart').getContext('2d');
            new Chart(topCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItemNames)),
                    datasets: [{
                        label: 'Qty sold',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItemCounts)),
                        backgroundColor: [
                            'rgba(25,135,84,0.75)',
                            'rgba(13,202,240,0.75)',
                            'rgba(255,193,7,0.75)',
                            'rgba(220,53,69,0.75)',
                            'rgba(111,66,193,0.75)'
                        ],
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, ticks: { stepSize: 1 } }
                    }
                }
            });
            </text>
        }
    </script>
}
