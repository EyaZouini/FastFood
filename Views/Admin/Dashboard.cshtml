@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Dashboard</h1>
    <span class="text-muted small">@DateTime.Now.ToString("dddd, MMMM dd yyyy")</span>
</div>

<!-- KPI cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="ff-summary-box d-flex align-items-center gap-3">
            <div class="ff-kpi-icon ff-kpi-icon-green">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <div>
                <div class="text-muted small">Revenue Today</div>
                <div class="fw-700 fs-5">$@Model.RevenueToday.ToString("0.00")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="ff-summary-box d-flex align-items-center gap-3">
            <div class="ff-kpi-icon ff-kpi-icon-blue">
                <i class="fas fa-calendar-alt"></i>
            </div>
            <div>
                <div class="text-muted small">Revenue This Month</div>
                <div class="fw-700 fs-5">$@Model.RevenueThisMonth.ToString("0.00")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="ff-summary-box d-flex align-items-center gap-3">
            <div class="ff-kpi-icon ff-kpi-icon-amber">
                <i class="fas fa-chart-line"></i>
            </div>
            <div>
                <div class="text-muted small">Total Revenue</div>
                <div class="fw-700 fs-5">$@Model.RevenueTotal.ToString("0.00")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="ff-summary-box d-flex align-items-center gap-3">
            <div class="ff-kpi-icon ff-kpi-icon-purple">
                <i class="fas fa-shopping-bag"></i>
            </div>
            <div>
                <div class="text-muted small">Total Orders</div>
                <div class="fw-700 fs-5">
                    @Model.TotalOrders
                    <span class="text-muted fs-6 fw-normal ms-1">(today: @Model.OrdersToday)</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="ff-summary-box">
            <h6 class="fw-700 mb-3">Orders — Last 7 Days</h6>
            <canvas id="ordersChart" height="110"></canvas>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="ff-summary-box">
            <h6 class="fw-700 mb-3">Top 5 Most Ordered Items</h6>
            @if (Model.TopItemNames.Count == 0)
            {
                <p class="text-muted text-center mt-4 mb-0">No order data yet.</p>
            }
            else
            {
                <canvas id="topItemsChart" height="160"></canvas>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        Chart.defaults.font.family = "'Inter', system-ui, sans-serif";
        Chart.defaults.color = '#6B7280';

        new Chart(document.getElementById('ordersChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrdersPerDayLabels)),
                datasets: [{
                    label: 'Orders',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OrdersPerDayCounts)),
                    backgroundColor: 'rgba(22,163,74,.75)',
                    borderRadius: 6,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#F3F4F6' } },
                          x: { grid: { display: false } } }
            }
        });

        @if (Model.TopItemNames.Count > 0)
        {
            <text>
            new Chart(document.getElementById('topItemsChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItemNames)),
                    datasets: [{
                        label: 'Qty sold',
                        data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopItemCounts)),
                        backgroundColor: ['rgba(22,163,74,.75)','rgba(37,99,235,.75)','rgba(217,119,6,.75)','rgba(220,38,38,.75)','rgba(124,58,237,.75)'],
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#F3F4F6' } },
                              y: { grid: { display: false } } }
                }
            });
            </text>
        }
    </script>
}
