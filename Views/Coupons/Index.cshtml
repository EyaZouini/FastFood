@model IEnumerable<FastFood.Models.Coupon>
@{
    ViewData["Title"] = "Coupons";
}

<div class="ff-page-header">
    <h1 class="ff-page-title">Coupons</h1>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Coupon</a>
</div>

<div class="ff-table-wrap">
    <table class="table ff-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Type</th>
                <th>Discount</th>
                <th>Min. Order</th>
                <th class="text-center">Picture</th>
                <th class="text-center">Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-600">@item.Title</td>
                    <td>@item.Type</td>
                    <td>
                        @if (item.Type == "Percent")
                        {
                            <span>@item.Discount%</span>
                        }
                        else
                        {
                            <span>$@item.Discount.ToString("0.00")</span>
                        }
                    </td>
                    <td>$@item.MinimumAmount.ToString("0.00")</td>
                    <td class="text-center">
                        @{
                            var base64 = Convert.ToBase64String(item.CouponPicture);
                            var imgsrc = $"data:image/jpg;base64,{base64}";
                        }
                        @if (item.CouponPicture.Length > 0)
                        {
                            <img src="@imgsrc" class="ff-cart-thumb" alt="@item.Title" />
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                    </td>
                    <td class="text-center">
                        <span class="ff-badge @(item.IsActive ? "ff-badge-active" : "ff-badge-inactive")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit"    asp-route-id="@item.Id" class="btn btn-outline-primary  btn-sm btn-action">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm btn-action">Details</a>
                        <a asp-action="Delete"  asp-route-id="@item.Id" class="btn btn-outline-danger   btn-sm btn-action">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
